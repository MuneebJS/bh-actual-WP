diff --git a/themes/enside/css/products-section.css b/themes/enside/css/products-section.css
new file mode 100644
index 0000000..8cc79af
--- /dev/null
+++ b/themes/enside/css/products-section.css
@@ -0,0 +1,62 @@
+/*
+ * Our Products Section Styles
+ * @package Enside
+ */
+
+.products-section {
+    padding: 60px 0;
+    background: #f7f8fa;
+    border-bottom: 1px solid #f0f0f0;
+}
+
+.products-section-title {
+    margin-bottom: 40px;
+    font-size: 28px;
+    color: #2a2f35;
+    text-transform: uppercase;
+    letter-spacing: 1px;
+}
+
+.products-list {
+    list-style: none;
+    padding: 0;
+    margin: 0;
+}
+
+.products-list-item {
+    padding: 18px 24px;
+    margin-bottom: 12px;
+    background: #ffffff;
+    border: 1px solid #f0f0f0;
+    border-radius: 3px;
+    font-size: 16px;
+    color: #2a2f35;
+    -webkit-transition: box-shadow 0.3s ease, border-color 0.3s ease;
+            transition: box-shadow 0.3s ease, border-color 0.3s ease;
+}
+
+.products-list-item:last-child {
+    margin-bottom: 0;
+}
+
+.products-list-item:hover {
+    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
+    border-color: #d8d8d8;
+}
+
+/* Responsive adjustments */
+@media (max-width: 767px) {
+    .products-section {
+        padding: 40px 0;
+    }
+
+    .products-section-title {
+        font-size: 22px;
+        margin-bottom: 28px;
+    }
+
+    .products-list-item {
+        font-size: 15px;
+        padding: 14px 18px;
+    }
+}
